<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         002 — yazio_foods
         Tabella alimenti Yazio (deprecata, mantenuta per compatibilità).
         Non più popolata attivamente.
         ================================================================ -->
    <changeSet id="002-create-yazio-foods" author="dsms">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="yazio_foods"/></not>
        </preConditions>
        <createTable tableName="yazio_foods">
            <column name="slug" type="TEXT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name_it" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="TEXT"/>
            <column name="kcal" type="NUMERIC(7,2)"/>
            <column name="protein_g" type="NUMERIC(7,2)"/>
            <column name="carbs_g" type="NUMERIC(7,2)"/>
            <column name="fat_g" type="NUMERIC(7,2)"/>
            <column name="scraped_at" type="TIMESTAMPTZ"
                    defaultValueComputed="now()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
